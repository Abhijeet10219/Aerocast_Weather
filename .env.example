# GEMINI_API_KEY: Required for Gemini AI API calls.
# For Vercel, add this in Project Settings -> Environment Variables.
# Never commit a real value to GitHub.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# For Vercel, set this to the production URL, for example:
# APP_URL=https://aerocast.vercel.app
APP_URL="MY_APP_URL"

# Open-Meteo customer key for the server-side weather feed (optional).
# For Vercel, add this in Project Settings -> Environment Variables.
# SECURITY: Keep this server-only. Never rename it with a VITE_ prefix or
# inject it through vite.config.ts.
OPEN_METEO_API_KEY=

# Google Maps Platform key. The browser map uses Maps JavaScript API, while the
# server can use the same key as a fallback for Google Weather API, Google Air
# Quality API, and Google Geocoding API if those APIs are enabled on the key.
# The key is bundled into browser code for Maps JS by design, so restrict it in
# Google Cloud to this app's HTTPS referrers and only the APIs you enable.
# For Vercel, add this in Project Settings -> Environment Variables instead of
# committing a .env file.
GOOGLE_MAPS_PLATFORM_KEY=
